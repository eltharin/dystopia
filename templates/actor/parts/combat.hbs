<section class="combat">

    <div class="flextabs">
        <div>
            <h2>
                <span>{{localizeSystem "sheet.actor.combat.arme.titre"}}</span>
                <span class="action add button" data-action="addItem" data-type="arme" title="{{localizeSystem "sheet.actor.combat.arme.ajout"}}">{{localizeSystem "sheet.actor.combat.arme.ajoutbtn"}}</span>
            </h2>

            <div class="tabitem">
                <div class="item arme titre">
                    <div class="lignetab">
                        <label ></label>
                        <label data-width="100px" style="--localwidth:100px">Cout Util.</label>
                        <label data-width="100px" style="--localwidth:100px">Dégats Base</label>
                        <label data-width="50px" style="--localwidth:50px">Actions</label>
                    </div>
                </div>

                {{#each armes as |item|}}
                    <div class="item arme">
                        <div class="lignetab">
                            <label data-action="attaqueRoll" data-arme="{{item._id}}">{{item.name}}</label>
                            
                            <label data-width="100px" style="--localwidth:100px">{{item.system.coutUtilisation}} PE</label>
                            <label data-width="100px" style="--localwidth:100px">{{item.system.degatsBase}}</label>

                            {{#if item.system.aptitude}}<label data-width="200" style="--localwidth:200px">{{localizeSystem (concat "sheet.actor.combat.arme.aptitude." item.system.aptitude ".name") }}</label>{{/if}}
                            <span class="action" >
                                {{#if item.system.notes}}<a data-action="toggle"  data-toggle="item_{{item._id}}"><i class="fas fa-eye"></i></a>{{/if}}
                                <a data-action="editItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.arme.edit"}}"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.arme.delete"}}"><i class="fas fa-trash"></i></a>
                            </span>    
                        </div>
                        {{#if item.system.notes}}
                        <div class="toggleable flexrow" data-toggle_section="item_{{item._id}}">
                            <div class="infos">      
                                {{item.system.notes}}
                            </div>
                        </div>
                        {{/if}}
                    </div>
                {{/each}}
            </div>

            <hr/>

            <h2>
                <span>{{localizeSystem "sheet.actor.combat.sort.titre"}}</span>
                <span class="action add button" data-action="addItem" data-type="sort" title="{{localizeSystem "sheet.actor.combat.sort.ajout"}}">{{localizeSystem "sheet.actor.combat.sort.ajoutbtn"}}</span>
            </h2>

            <div class="tabitem">
                <div class="item sort titre">
                    <div class="lignetab">
                        <label ></label>
                        <label data-width="50px" style="--localwidth:50px">Actions</label>
                    </div>
                </div>

                {{#each sorts as |item|}}
                    <div class="item sort">
                        <div class="lignetab">
                            <label data-action="attaqueRoll" data-arme="{{item._id}}">{{item.name}}</label>
                            {{#if item.system.aptitude}}<label data-width="200" style="--localwidth:200px">{{localizeSystem (concat "sheet.actor.combat.arme.aptitude." item.system.aptitude ".name") }}</label>{{/if}}
                            <span class="action" >
                                {{#if item.system.notes}}<a data-action="toggle"  data-toggle="item_{{item._id}}"><i class="fas fa-eye"></i></a>{{/if}}
                                <a data-action="editItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.arme.edit"}}"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.arme.delete"}}"><i class="fas fa-trash"></i></a>
                            </span>    
                        </div>
                        {{#if item.system.notes}}
                        <div class="toggleable flexrow" data-toggle_section="item_{{item._id}}">
                            <div class="infos">      
                                {{item.system.notes}}
                            </div>
                        </div>
                        {{/if}}
                    </div>
                {{/each}}
            </div>

            <hr/>

            <h2>
                <span>{{localizeSystem "sheet.actor.combat.armure.titre"}}</span>
                <span class="action add button" data-action="addItem" data-type="armure" title="{{localizeSystem "sheet.actor.combat.armure.ajout"}}">{{localizeSystem "sheet.actor.combat.armure.ajoutbtn"}}</span>
            </h2>

            <div class="tabitem">
                <div class="item armure titre">
                    <div class="lignetab">
                        <label ></label>
                        <label data-width="100px" style="--localwidth:100px">Bonus Armure</label>
                        <label data-width="100px" style="--localwidth:100px">Cout Deplacement</label>
                        <label data-width="50px" style="--localwidth:50px">Actions</label>
                    </div>
                </div>
                {{#each armures as |item|}}
                    <div class="item armure">
                        <div class="lignetab">
                            <label>{{item.name}}</label>
                            
                            <label data-width="100px" style="--localwidth:100px">{{item.system.bonusArmure}}</label>
                            <label data-width="100px" style="--localwidth:100px">{{item.system.coutDeplacement}}</label>

                            <span class="action" >
                                {{#if item.system.notes}}<a data-action="toggle"  data-toggle="item_{{item._id}}"><i class="fas fa-eye"></i></a>{{/if}}
                                <a data-action="editItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.armure.edit"}}"><i class="fas fa-edit"></i></a>
                                <a data-action="deleteItem" data-itemid="{{item.id}}" title="{{localizeSystem "sheet.actor.combat.armure.delete"}}"><i class="fas fa-trash"></i></a>
                            </span>    
                        </div>
                        {{#if item.system.notes}}
                        <div class="toggleable flexrow" data-toggle_section="item_{{item._id}}">
                            <div class="infos">      
                                {{item.system.notes}}
                            </div>
                        </div>
                        {{/if}}
                    </div>
                {{/each}}
            </div>
        </div>
    
    </div>

</section>