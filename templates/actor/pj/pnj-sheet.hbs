<div class="sheet {{ SYSTEMID }} pj-sheet">
    <div class="sidebar">
        {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/sidebar.hbs" }}
    </div>
    <div class="content">
        <div class="top">
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/topbar.hbs" }}
        </div>
        <div class="main">
            <nav class="sheet-tabs tabs" data-application-part="tabs">
                <a data-action="tab" data-group="primary" data-tab="aspects">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.aspects"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="prouesses">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.prouesses"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="magie">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.magie"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="equipements">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.equipements"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="consequences">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.consequences"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="combat">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.combat"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="notes">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.notes"}}</span>
                </a>
                <a data-action="tab" data-group="primary" data-tab="max">
                    <span>{{localize SYSTEMID + ".pjsheet.tabs.max"}}</span>
                </a>
            </nav>
            <div class="pages">
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/aspects.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/prouesses.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/magie.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/consequences.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/combat.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/equipements.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/notes.hbs" }}
            {{> concat (SYSTEMTEMPLATE) "/actor/pj/parts/max.hbs" }}
            </div>
        </div>
    </div>
</div>