<div class="dice-roll" data-action="expandRoll">
    <div class="dice-result">
        <div class="dice-formula">{{seuil}}</div>
        <div class="dice-formula">{{bonus}}</div>
        <div class="dice-formula">{{critique}}</div>
        {{{tooltip}}}
        <div class="dice-formula">{{localize (concat (SYSTEMID) ".roll.common.total")}} : {{total}}</div>

        
        <h4 class="dice-total">{{result}}</h4>

        
        {{#if actions}}
        <div class="actions">
            {{#each actions as |action|}}
                <button data-action="{{action.action}}"
                {{#each action.data as |data|}}
                     data-{{data.key}}="{{data.value}}"
                {{/each}}
                >{{action.label}}</button>
            {{/each}}
        </div>
        {{/if}}  
    </div>
</div>
